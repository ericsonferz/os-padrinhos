{
  "name": "@ospadrinhos/root",
  "version": "0.1.0",
  "private": true,
  "description": "Os Padrinhos Monorepo",
  "type": "module",
  "packageManager": "npm@11",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "git clean -xfd",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.2.0",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4"
  }
}